generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Freelancers (primary users) ──────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  avatarUrl       String?
  brandColor      String   @default("#E8A838")
  logoUrl         String?
  subdomain       String?  @unique
  welcomeMessage  String?
  stripeAccountId String?
  plan            Plan     @default(FREE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clients       Client[]
  projects      Project[]
  invoices      Invoice[]
  contracts     Contract[]
  notifications Notification[]

  @@map("users")
}

enum Plan {
  FREE
  SOLO
  PRO
}

// ── Clients ──────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String
  company   String?
  avatarUrl String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]
  invoices      Invoice[]
  contracts     Contract[]
  notifications Notification[]

  @@unique([userId, email])
  @@map("clients")
}

// ── Projects ─────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  columns  Column[]
  files    File[]
  reviews  Review[]
  invoices Invoice[]
  contracts Contract[]
  messages  Message[]
  activities Activity[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

// ── Kanban Board ─────────────────────────────────────────────

model Column {
  id        String @id @default(cuid())
  projectId String
  name      String
  position  Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@map("columns")
}

model Card {
  id          String    @id @default(cuid())
  columnId    String
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  position    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@map("cards")
}

// ── Files & Deliverables ─────────────────────────────────────

model File {
  id            String   @id @default(cuid())
  projectId     String
  uploadedById  String
  uploaderType  ActorType
  name          String
  url           String
  size          Int
  mimeType      String
  version       Int      @default(1)
  isDeliverable Boolean  @default(false)
  createdAt     DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("files")
}

// ── Design Review ────────────────────────────────────────────

model Review {
  id        String       @id @default(cuid())
  projectId String
  fileId    String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  annotations Annotation[]

  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

model Annotation {
  id         String    @id @default(cuid())
  reviewId   String
  authorId   String
  authorType ActorType
  x          Float
  y          Float
  comment    String
  isResolved Boolean   @default(false)
  parentId   String?
  createdAt  DateTime  @default(now())

  review  Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent  Annotation? @relation("AnnotationThread", fields: [parentId], references: [id])
  replies Annotation[] @relation("AnnotationThread")

  @@map("annotations")
}

// ── Invoicing ────────────────────────────────────────────────

model Invoice {
  id                    String        @id @default(cuid())
  projectId             String
  clientId              String
  userId                String
  lineItems             Json
  subtotal              Int           // cents
  tax                   Int           @default(0)
  total                 Int           // cents
  status                InvoiceStatus @default(DRAFT)
  dueDate               DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
}

// ── Contracts & Proposals ────────────────────────────────────

model Contract {
  id         String    @id @default(cuid())
  projectId  String
  clientId   String
  userId     String
  title      String
  content    String    // rich text / markdown
  signedAt   DateTime?
  signerName String?
  signerIp   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

// ── Messaging ────────────────────────────────────────────────

model Message {
  id         String    @id @default(cuid())
  projectId  String
  senderId   String
  senderType ActorType
  content    String
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ── Activity Log ─────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  projectId String
  actorId   String
  actorType ActorType
  action    ActivityType
  metadata  Json?
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("activities")
}

enum ActivityType {
  PROJECT_CREATED
  STATUS_CHANGED
  FILE_UPLOADED
  DELIVERABLE_MARKED
  REVIEW_CREATED
  REVIEW_APPROVED
  REVIEW_CHANGES_REQUESTED
  COMMENT_ADDED
  INVOICE_SENT
  INVOICE_PAID
  CONTRACT_SENT
  CONTRACT_SIGNED
  MESSAGE_SENT
}

// ── Notifications ────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  clientId  String?
  type      NotificationType
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  FILE_UPLOADED
  STATUS_CHANGED
  REVIEW_REQUESTED
  COMMENT_RECEIVED
  INVOICE_SENT
  INVOICE_PAID
  CONTRACT_SIGNED
  MESSAGE_RECEIVED
}

// ── Shared Enums ─────────────────────────────────────────────

enum ActorType {
  USER
  CLIENT
}
