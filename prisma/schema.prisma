generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Freelancers (primary users) ──────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String?
  avatarUrl       String?
  brandColor      String   @default("#E8A838")
  logoUrl         String?
  subdomain       String?  @unique
  welcomeMessage  String?
  stripeAccountId String?
  plan            Plan     @default(FREE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clients        Client[]
  projects       Project[]
  invoices       Invoice[]
  pipelineStages PipelineStage[]
  meetings       Meeting[]

  @@map("users")
}

enum Plan {
  FREE
  SOLO
  PRO
}

// ── Clients ──────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String
  company   String?
  avatarUrl String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  projects Project[]
  invoices Invoice[]
  meetings Meeting[]

  @@unique([userId, email])
  @@map("clients")
}

// ── Contacts ─────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  title     String?  // e.g. "Marketing Lead", "CEO", "Billing"
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contacts")
}

// ── Pipeline Stages (global per user) ────────────────────────

model PipelineStage {
  id        String   @id @default(cuid())
  userId    String
  name      String
  position  Int
  color     String   @default("#E55A3A") // fire by default
  isDefault Boolean  @default(false)     // one stage marks the default for new projects
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("pipeline_stages")
}

// ── Projects ─────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  stageId     String?
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  stagePosition Int         @default(0)  // order within its pipeline stage
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stage      PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  files      File[]
  reviews    Review[]
  invoices   Invoice[]
  activities Activity[]
  meetings   Meeting[]

  @@index([userId, stageId, stagePosition])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

// ── Files & Deliverables ─────────────────────────────────────

model File {
  id            String   @id @default(cuid())
  projectId     String
  uploadedById  String
  uploaderType  ActorType
  name          String
  url           String
  size          Int
  mimeType      String
  version       Int      @default(1)
  isDeliverable Boolean  @default(false)
  createdAt     DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([projectId])
  @@map("files")
}

// ── Design Review ────────────────────────────────────────────

model Review {
  id        String       @id @default(cuid())
  projectId String
  fileId    String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  annotations Annotation[]

  @@index([fileId])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

model Annotation {
  id         String    @id @default(cuid())
  reviewId   String
  authorId   String
  authorType ActorType
  x          Float
  y          Float
  comment    String
  isResolved Boolean   @default(false)
  parentId   String?
  createdAt  DateTime  @default(now())

  review  Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent  Annotation? @relation("AnnotationThread", fields: [parentId], references: [id])
  replies Annotation[] @relation("AnnotationThread")

  @@index([reviewId])
  @@map("annotations")
}

// ── Invoicing ────────────────────────────────────────────────

model Invoice {
  id                    String        @id @default(cuid())
  projectId             String
  clientId              String
  userId                String
  lineItems             Json
  subtotal              Int           // cents
  tax                   Int           @default(0)
  total                 Int           // cents
  status                InvoiceStatus @default(DRAFT)
  dueDate               DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([projectId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
}

// ── Activity Log ─────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  projectId String
  actorId   String
  actorType ActorType
  action    ActivityType
  metadata  Json?
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("activities")
}

enum ActivityType {
  PROJECT_CREATED
  STATUS_CHANGED
  FILE_UPLOADED
  DELIVERABLE_MARKED
  REVIEW_CREATED
  REVIEW_APPROVED
  REVIEW_CHANGES_REQUESTED
  COMMENT_ADDED
  INVOICE_SENT
  INVOICE_PAID
}

// ── Meetings ──────────────────────────────────────────────────

model Meeting {
  id          String      @id @default(cuid())
  userId      String
  clientId    String?
  projectId   String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  type        MeetingType @default(GENERAL)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startTime])
  @@map("meetings")
}

enum MeetingType {
  DISCOVERY
  KICKOFF
  CHECK_IN
  REVIEW
  PRESENTATION
  GENERAL
}

// ── Shared Enums ─────────────────────────────────────────────

enum ActorType {
  USER
  CLIENT
}
