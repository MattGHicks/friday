generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Freelancers (primary users) ──────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String?
  avatarUrl       String?
  brandColor      String   @default("#E8A838")
  logoUrl         String?
  subdomain       String?  @unique
  welcomeMessage  String?
  stripeAccountId String?
  plan            Plan     @default(FREE)
  firstPortalInviteSentAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clients        Client[]
  projects       Project[]
  invoices       Invoice[]
  pipelineStages PipelineStage[]
  meetings       Meeting[]
  leads          Lead[]
  quotes         Quote[]
  activities     Activity[]

  @@map("users")
}

enum Plan {
  FREE
  SOLO
  PRO
}

// ── Clients ──────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String
  company   String?
  avatarUrl String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  projects Project[]
  invoices Invoice[]
  meetings Meeting[]
  quotes   Quote[]

  @@unique([userId, email])
  @@map("clients")
}

// ── Contacts ─────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  title     String?  // e.g. "Marketing Lead", "CEO", "Billing"
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contacts")
}

// ── Pipeline Stages (global per user) ────────────────────────

model PipelineStage {
  id        String   @id @default(cuid())
  userId    String
  name      String
  position  Int
  color     String   @default("#E55A3A") // fire by default
  isDefault Boolean  @default(false)     // one stage marks the default for new projects
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@map("pipeline_stages")
}

// ── Leads ─────────────────────────────────────────────────────
//
// A prospective client who has not yet accepted a quote / paid a deposit.
// On deposit-paid, a Lead converts to a real Client + Project.

model Lead {
  id                  String     @id @default(cuid())
  userId              String
  name                String
  email               String?
  phone               String?
  company             String?
  source              String?
  notes               String?
  pipelineStageId     String?
  stagePosition       Int        @default(0)
  status              LeadStatus @default(ACTIVE)
  convertedClientId   String?
  convertedProjectId  String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineStage PipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  quotes        Quote[]

  @@index([userId, pipelineStageId, stagePosition])
  @@map("leads")
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

// ── Quotes ───────────────────────────────────────────────────

model Quote {
  id             String      @id @default(cuid())
  userId         String
  leadId         String?
  clientId       String?
  subject        String
  subtotal       Int         // cents
  total          Int         // cents
  depositAmount  Int         @default(0) // cents
  depositType    DepositType @default(PERCENT)
  validUntil     DateTime?
  status         QuoteStatus @default(DRAFT)
  publicToken    String      @unique @default(cuid())
  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  declinedAt     DateTime?
  depositPaidAt  DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client    Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lineItems QuoteLineItem[]
  invoices  Invoice[]

  @@index([userId, status])
  @@index([leadId])
  @@index([clientId])
  @@map("quotes")
}

model QuoteLineItem {
  id          String @id @default(cuid())
  quoteId     String
  description String
  quantity    Int    @default(1)
  unitPrice   Int    // cents
  total       Int    // cents
  position    Int    @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_line_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum DepositType {
  FIXED
  PERCENT
}

// ── Projects ─────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  files      File[]
  reviews    Review[]
  invoices   Invoice[]
  activities Activity[]
  meetings   Meeting[]
  thread     Thread?

  @@index([userId, status])
  @@map("projects")
}

// ── Messaging ────────────────────────────────────────────────
//
// One thread per project. Per-thread inbound token used to route
// replies: outbound emails set replyTo to reply+<inboundToken>@itsfriday.dev
// and Resend's inbound webhook parses the token back out.

model Thread {
  id           String   @id @default(cuid())
  projectId    String   @unique
  inboundToken String   @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("threads")
}

model Message {
  id              String            @id @default(cuid())
  threadId        String
  authorType      MessageAuthorType
  authorUserId    String?           // for USER messages
  authorClientId  String?           // for CLIENT messages (from known contacts)
  authorEmail     String?           // fallback email for unknown senders or audit
  authorName      String?           // display name (from email "From" or contact)
  body            String            // sanitized plain text / minimal HTML
  systemEventType SystemEventType?  // set when authorType=SYSTEM
  systemMetadata  Json?             // metadata for system events (fileName, invoiceTotal, etc)
  createdAt       DateTime          @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("messages")
}

enum MessageAuthorType {
  USER
  CLIENT
  SYSTEM
}

enum SystemEventType {
  FILE_UPLOADED
  REVIEW_APPROVED
  REVIEW_CHANGES_REQUESTED
  INVOICE_SENT
  INVOICE_PAID
  QUOTE_SENT
  QUOTE_ACCEPTED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

// ── Files & Deliverables ─────────────────────────────────────

model File {
  id            String   @id @default(cuid())
  projectId     String
  uploadedById  String
  uploaderType  ActorType
  name          String
  url           String
  size          Int
  mimeType      String
  version       Int      @default(1)
  isDeliverable Boolean  @default(false)
  createdAt     DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([projectId])
  @@map("files")
}

// ── Design Review ────────────────────────────────────────────

model Review {
  id        String       @id @default(cuid())
  projectId String
  fileId    String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  annotations Annotation[]

  @@index([fileId])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

model Annotation {
  id         String    @id @default(cuid())
  reviewId   String
  authorId   String
  authorType ActorType
  x          Float
  y          Float
  comment    String
  isResolved Boolean   @default(false)
  parentId   String?
  createdAt  DateTime  @default(now())

  review  Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent  Annotation? @relation("AnnotationThread", fields: [parentId], references: [id])
  replies Annotation[] @relation("AnnotationThread")

  @@index([reviewId])
  @@map("annotations")
}

// ── Invoicing ────────────────────────────────────────────────

model Invoice {
  id                    String        @id @default(cuid())
  projectId             String
  clientId              String
  userId                String
  lineItems             Json
  subtotal              Int           // cents
  tax                   Int           @default(0)
  total                 Int           // cents
  status                InvoiceStatus @default(DRAFT)
  dueDate               DateTime?
  paidAt                DateTime?
  stripePaymentIntentId String?
  notes                 String?
  quoteId               String?
  isDeposit             Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([projectId])
  @@index([quoteId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
}

// ── Activity Log ─────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  userId    String       // freelancer this activity belongs to
  projectId String?      // null for pre-project events (quote sent, declined, viewed)
  actorId   String
  actorType ActorType
  action    ActivityType
  metadata  Json?
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId])
  @@map("activities")
}

enum ActivityType {
  PROJECT_CREATED
  STATUS_CHANGED
  FILE_UPLOADED
  DELIVERABLE_MARKED
  REVIEW_CREATED
  REVIEW_APPROVED
  REVIEW_CHANGES_REQUESTED
  COMMENT_ADDED
  INVOICE_SENT
  INVOICE_PAID
  QUOTE_SENT
  QUOTE_VIEWED
  QUOTE_ACCEPTED
  QUOTE_DECLINED
}

// ── Meetings ──────────────────────────────────────────────────

model Meeting {
  id          String      @id @default(cuid())
  userId      String
  clientId    String?
  projectId   String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  type        MeetingType @default(GENERAL)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startTime])
  @@map("meetings")
}

enum MeetingType {
  DISCOVERY
  KICKOFF
  CHECK_IN
  REVIEW
  PRESENTATION
  GENERAL
}

// ── Shared Enums ─────────────────────────────────────────────

enum ActorType {
  USER
  CLIENT
}
